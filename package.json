{
  "name": "zodrift",
  "version": "0.1.2",
  "description": "ESLint-style CI drift checker for TypeScript types and Zod schemas.",
  "author": "greyllmmoder",
  "homepage": "https://github.com/greyllmmoder/zodrift#readme",
  "bugs": {
    "url": "https://github.com/greyllmmoder/zodrift/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greyllmmoder/zodrift.git"
  },
  "type": "module",
  "license": "MIT",
  "bin": {
    "zodrift": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "check": "npm run dev -- check",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "zodrift",
    "eslint-for-zod",
    "zod",
    "typescript",
    "schema",
    "drift",
    "drift-detection",
    "schema-validation",
    "api-contracts",
    "type-safety",
    "ci",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0"
  },
  "dependencies": {
    "typescript": "^5.8.3",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public"
  }
}
